# SANITY CMS: Required when production content should come from Sanity.
# Add these same variables in Vercel Project Settings -> Environment Variables.
VITE_SANITY_PROJECT_ID="your_sanity_project_id"
VITE_SANITY_DATASET="production"
VITE_SANITY_API_VERSION="2025-06-01"
VITE_SANITY_USE_CDN="true"

# Optional legacy AI Studio variables. The public website does not require them.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
APP_URL="MY_APP_URL"
